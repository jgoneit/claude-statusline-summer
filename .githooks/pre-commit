#!/bin/bash
#
# Pre-commit safety checks for claude-statusline-summer.
# Enabled via:  git config core.hooksPath .githooks

status=0
staged=$(git diff --cached --name-only)

# 1) Never commit the machine-specific local settings (absolute paths).
if printf '%s\n' "$staged" | grep -qx '.claude/settings.local.json'; then
  echo "✗ Refusing to commit .claude/settings.local.json (machine-specific; it is gitignored)." >&2
  echo "  Run: git restore --staged .claude/settings.local.json" >&2
  status=1
fi

# 2) Syntax-check the status line script whenever it's part of the commit.
if printf '%s\n' "$staged" | grep -qx 'statusline.sh'; then
  if ! bash -n statusline.sh; then
    echo "✗ statusline.sh has a syntax error (bash -n). Fix before committing." >&2
    status=1
  fi
  if command -v shellcheck >/dev/null 2>&1; then
    shellcheck -S warning statusline.sh || { echo "✗ shellcheck reported issues in statusline.sh." >&2; status=1; }
  fi
fi

exit $status
