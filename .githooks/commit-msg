#!/bin/bash
#
# Enforce Conventional Commits on the subject line.
# https://www.conventionalcommits.org/
# Format: <type>(<optional scope>)<optional !>: <description>
#
# Enabled via:  git config core.hooksPath .githooks

msg_file="$1"
subject=$(head -n1 "$msg_file")

# Let git's own housekeeping / fixup commits through untouched.
case "$subject" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"Initial commit") exit 0 ;;
esac

types='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'
if printf '%s' "$subject" | grep -Eq "^(${types})(\([a-z0-9._/-]+\))?!?: .+"; then
  exit 0
fi

cat >&2 <<EOF
✗ Commit message doesn't follow Conventional Commits.

  Got:      $subject
  Expected: <type>(<optional scope>): <description>
  Types:    feat fix docs style refactor perf test build ci chore revert
  Examples: feat(heat): add 5-tier summer temperature gauge
            fix: guard against null context_window
            docs(readme): document the portable install

  (Merge / Revert / fixup! / squash! commits are exempt.)
EOF
exit 1
